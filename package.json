{
  "name": "imgto-link-publisher-monorepo",
  "private": true,
  "scripts": {
    "build": "cd apps/extension && bun run build",
    "build:firefox": "cd apps/extension && bun run build:firefox",
    "build:safari": "cd apps/extension && bun run build:safari",
    "dev": "cd apps/extension && bun run dev",
    "dev:chrome": "cd apps/extension && bun run dev:chrome",
    "dev:watch": "cd apps/extension && bun run dev:watch",
    "lint": "cd apps/extension && bun run lint"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
